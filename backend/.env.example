# Server
PORT=5000
NODE_ENV=development

# CORS - comma separated list of allowed origins
CLIENT_URL=http://localhost:5173

# Upload limits
MAX_UPLOAD_SIZE_MB=500
MAX_UPLOAD_FILES=200
ALLOWED_MIME_TYPES=video/mp4
ALLOWED_EXTENSIONS=.mp4

# Storage paths (relative to backend root)
UPLOAD_DIR=uploads
CONVERTED_DIR=converted

# File cleanup - how long (in minutes) to keep files before automatic deletion
FILE_RETENTION_MINUTES=60
# How often (in minutes) the cleanup job runs
CLEANUP_INTERVAL_MINUTES=15

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=1000

# Concurrency: max FFmpeg processes running simultaneously
MAX_CONCURRENT_CONVERSIONS=4

# Default audio quality (kbps): 128 | 192 | 256 | 320
DEFAULT_AUDIO_BITRATE=192
